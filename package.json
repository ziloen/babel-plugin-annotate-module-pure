{
  "name": "babel-plugin-annotate-module-pure",
  "version": "1.0.4",
  "description": "Mark module method calls as pure for tree shaking",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "release": "npm run compile && bumpp --commit --no-push && npm publish",
    "compile": "tsc --project tsconfig.json --removeComments && tsc --project tsconfig.json --emitDeclarationOnly",
    "test": "node --test"
  },
  "keywords": [
    "babel",
    "plugin"
  ],
  "files": [
    "dist"
  ],
  "dependencies": {
    "@babel/core": "^7",
    "@babel/types": "^7"
  },
  "peerDependencies": {
    "@babel/core": "^7",
    "@babel/types": "^7"
  },
  "devDependencies": {
    "@types/babel__core": "7.20.5",
    "@types/node": "24.12.2",
    "bumpp": "11.1.0",
    "typescript": "6.0.3"
  }
}
